module main
import io

struct Point {
    x: int,
    y: int
}

impl Point {
    constructor(x: int, y: int) {
        self.x = x
        self.y = y
    }
}

func add(p: Point): int {
    return p.x + p.y
}

func main(): int {
    var name: str = "Gobol"
    var arr: int[10][10]
    arr[2][2] = 114514
    var flag: bool = true
    io.print(@"Hello from {name}\n")
    io.print(@"arr[2] is {arr[2][2]}!\n")

    for i in 0..10 {
        io.print(@"Number {i}\n")
    }

    var p: Point = Point(1, 2)
    
    io.print(@"Calc: {add(p)}\n")

    if arr[2][2] == 114514 {
        io.print("Right!\n")
    } else {
        io.print("Wrong!\n")
    }
    
    /*
    while true {
        io.print("While!\n")
    }
    */
    io.print("End of Task!\n")
    return 0
}
