import io;

struct Point {
    x: int,
    y: int,
};

impl Point {
    func new(x: int, y: int): Point {
        self.x = x;
        self.y = y;
        self
    }

    func distance(self): float {
        (self.x * self.x + self.y * self.y) as float
    }
}

func main() {
    var p = Point.new(3, 4);
    io.println(@"distance: {p.distance()}");
}
