import io;

struct Rect {
    width: int,
    height: int,
};

impl Rect {
    func new(w: int, h: int): Rect {
        self.width = w;
        self.height = h;
        self
    }

    func area(self): int {
        self.width * self.height
    }
}

func main() {
    var r = Rect.new(10, 20);
    io.println(@"area: {r.area()}");
}
