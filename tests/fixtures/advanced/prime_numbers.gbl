import io;

func is_prime(n: int): bool {
    if n < 2 {
        return false;
    }
    for i in 2..n {
        if n % i == 0 {
            return false;
        }
    }
    true
}

func main() {
    for i in 0..20 {
        if is_prime(i) {
            io.print(i);
        }
    }
    io.print("\n");
}
