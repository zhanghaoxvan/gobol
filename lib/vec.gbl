// user don't need this name directly
// it's the base database of the gobol
// when user use the 'type[<the inital count of the vec and don't must complete this>]'
// like var v: int[] => var v: new vec<int>()
// or var v1: int[32] => var v1: new vec<int>()
// it calls this library
#[library_features(hidden = true)]
module vec

struct vec<T> {
    _data: T[]?,
    _len: int,
    _cap: int
}

impl<T> vec<T> {
    constructor(): vec<T> {
        _data = null
        _len = 0
        _cap = 0
        return self
    }
    
    constructor(capacity: int): vec<T> {
        _data = new T[capacity]?
        _len = 0
        _cap = capacity
        return self
    }
    
    func len(self): int { return _len }
    func cap(self): int { return _cap }
    func is_empty(self): bool { return _len == 0 }
    
    func get(self, index: int): T {
        if index < 0 || index >= _len { panic("index out of bounds") }
        return _data[index]
    }
    
    func set(self, index: int, value: T) {
        if index < 0 || index >= _len { panic("index out of bounds") }
        _data[index] = value
    }
    
    func push(self, value: T) {
        if _len >= _cap { _grow(self) }
        if _data == null {
            _data = new T[4]?
            _cap = 4
        }
        _data[_len] = value
        _len += 1
    }
    
    func pop(self): T {
        if _len == 0 { panic("pop from empty vec") }
        _len -= 1
        let value = _data[_len]
        _data[_len] = null
        return value
    }
    
    convert T[](self): T[] {
        let result: T[] = new T[_len]
        for i in 0.._len {
            result[i] = _data[i]
        }
        return result
    }
    
    iter(self) {
        return vec_iterator(_data, _len)
    }
}

func _grow<T>(self: vec<T>) {
    let new_cap = if _cap == 0 { 4 } else { _cap * 2 }
    let new_data: T[] = new T[new_cap]?
    for i in 0.._len {
        new_data[i] = _data[i]
    }
    _data = new_data
    _cap = new_cap
}

struct vec_iterator<T> {
    _data: T[]?,
    _len: int,
    _index: int
}

impl<T> vec_iterator<T> {
    constructor(data: T[]?, len: int): vec_iterator<T> {
        _data = data
        _len = len
        _index = 0
        return self
    }
    
    func next(self): (T, bool) {
        if _index >= _len { return (null, false) }
        let value = _data[_index]
        _index += 1
        return (value, true)
    }
}

// ==================== 运算符重载（全局函数）====================
operator [](self: vec<T>, index: int): T {
    return self.get(index)
}

operator []=(self: vec<T>, index: int, value: T) {
    self.set(index, value)
}

operator +(left: vec<T>, right: vec<T>): vec<T> {
    let result = vec<T>.new()
    for i in 0..left.len() {
        result.push(left[i])
    }
    for i in 0..right.len() {
        result.push(right[i])
    }
    return result
}

operator ==(left: vec<T>, right: vec<T>): bool {
    if left.len() != right.len() { return false }
    for i in 0..left.len() {
        if left[i] != right[i] { return false }
    }
    return true
}

// ==================== 导出 ====================
#[internal]
export(vec)
