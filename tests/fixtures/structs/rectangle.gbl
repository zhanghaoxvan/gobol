import io;

struct Rectangle {
    width: int,
    height: int,
};

impl Rectangle {
    func new(w: int, h: int): Rectangle {
        self.width = w;
        self.height = h;
        self
    }

    func area(self): int {
        self.width * self.height
    }

    func perimeter(self): int {
        2 * (self.width + self.height)
    }
}

func main() {
    var r = Rectangle(3, 4);
    io.println(@"area: {r.area()}");
    io.println(@"perimeter: {r.perimeter()}");
}
