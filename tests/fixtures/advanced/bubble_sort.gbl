import io;

func bubble_sort(arr: int[]) {
    var n = arr.len();
    for i in 0..n {
        for j in 0..(n - 1) {
            if arr[j] > arr[j + 1] {
                var tmp = arr[j];
                arr[j] = arr[j + 1];
                arr[j + 1] = tmp;
            }
        }
    }
}

func main() {
    var arr: int[] = [5, 3, 8, 1, 9, 2];
    bubble_sort(arr);
    for i in arr {
        io.print(i);
    }
    io.print("\n");
}
