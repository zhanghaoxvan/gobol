#[library_features(hidden = true)]

struct range {
    _start: int,
    _end: int,
    _step: int
}

struct range_iterator {
    _current: int,
    _end: int,
    _step: int
}

impl range {
    func new(start: int, end: int): range {
        _start = start;
        _end = end;
        _step = 1;
        self
    }

    func new(start: int, end: int, step: int): range {
        _start = start;
        _end = end;
        _step = step;
        self
    }

    convert int[](self): int[] {
        var result: int[];
        var i: int = _start;
        if _step > 0 {
            while i < _end {
                result.add(i);
                i += _step;
            }
        } else {
            while i > _end {
                result.add(i);
                i += _step;
            }
        }
        result
    }

    iter(self): range_iterator {
        range_iterator(_start, _end, _step)
    }

    func start(self): int { _start }
    func end(self): int { _end }
    func step(self): int { _step }

    func len(self): int {
        if _step == 0 { return 0; }
        (_end - _start + _step - 1) / _step
    }

    func contains(self, value: int): bool {
        if _step > 0 {
            value >= _start && value < _end && (value - _start) % _step == 0
        } else {
            value <= _start && value > _end && (value - _start) % _step == 0
        }
    }
}

impl range_iterator {
    func new(current: int, end: int, step: int): range_iterator {
        _current = current;
        _end = end;
        _step = step;
        self
    }

    func next(self): (int, bool) {
        if _step > 0 {
            if _current >= _end { return (0, false); }
        } else {
            if _current <= _end { return (0, false); }
        }
        var value: int = _current;
        _current += _step;
        (value, true)
    }
}

export(range, range_iterator)
