import io;

struct Point {
    x: int,
    y: int,
};

impl Point {
    func new(x: int, y: int): Point {
        self.x = x;
        self.y = y;
        self
    }

    convert str(self): str {
        @"({self.x}, {self.y})"
    }
}

func main() {
    var p = Point(3, 4);
    io.println(@"p as str = {p as str}");
}
